{
    "version": "0.6.8",
    "description": "Agent-to-Agent communication protocol for CLI agents",
    "homepage": "https://github.com/s-hiraoku/synapse-a2a",
    "license": "MIT",
    "depends": "python",
    "url": "https://files.pythonhosted.org/packages/de/24/4a11881d3842f5f0c7e7ba63964b11ee1f37612248317f8c80c53c2f91c4/synapse_a2a-0.6.8.tar.gz",
    "hash": "2c7418e3d36dc37c05fcdbc04a092c08274e8ecd2e16fb538f05c9c642377ddf",
    "installer": {
        "script": [
            "$venvDir = \"$dir\\venv\"",
            "python -m venv $venvDir",
            "& \"$venvDir\\Scripts\\pip.exe\" install --no-cache-dir synapse-a2a==$version"
        ]
    },
    "uninstaller": {
        "script": [
            "Remove-Item -Recurse -Force \"$dir\\venv\" -ErrorAction SilentlyContinue"
        ]
    },
    "bin": [
        [
            "venv\\Scripts\\synapse.exe",
            "synapse"
        ]
    ],
    "checkver": {
        "url": "https://pypi.org/pypi/synapse-a2a/json",
        "jsonpath": "$.info.version"
    },
    "autoupdate": {
        "url": "https://files.pythonhosted.org/packages/source/s/synapse-a2a/synapse_a2a-$version.tar.gz"
    },
    "notes": [
        "Synapse A2A uses pty.spawn() which requires a Unix-like terminal.",
        "Windows native is NOT supported. Please use WSL2 for full functionality.",
        "See: https://github.com/s-hiraoku/synapse-a2a#prerequisites"
    ]
}
